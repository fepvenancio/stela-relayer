# StarkNet RPC endpoint (must support v0.8 spec for V3 transactions)
RPC_URL=https://starknet-sepolia.g.alchemy.com/starknet/version/rpc/v0_8/YOUR_KEY

# Relayer wallet credentials
RELAYER_PRIVATE_KEY=0x...
RELAYER_ADDRESS=0x...

# Stela API base URL (any Stela frontend instance)
STELA_API_URL=https://stela-dapp.xyz

# Stela protocol contract address
STELA_ADDRESS=0x03e88d289b9ce13e5d6e6ca5159930f9227b08cfbd004231a09a1d6f48568973

# Poll interval in milliseconds (default: 120000 = 2 minutes)
POLL_INTERVAL_MS=120000
